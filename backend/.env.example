# ---- Server ----
PORT=5000

# Comma-separated list of allowed frontend origins (CORS).
# Example: http://localhost:3000,https://your-frontend.vercel.app
CLIENT_URL=http://localhost:3000

# ---- Database ----
# MongoDB Atlas connection string.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/travel-planner?retryWrites=true&w=majority

# ---- Auth ----
# Use a long, random secret in production (e.g. `openssl rand -hex 32`).
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ---- AI (Google Gemini) ----
# Free key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
